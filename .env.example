# Admin login
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Firebase Admin SDK
# Create a Firebase service account key, then copy these values from the JSON file.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional, but needed for permanent product image uploads.
# Usually: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=
